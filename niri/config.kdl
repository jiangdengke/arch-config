// 此配置文件使用 KDL 格式：https://kdl.dev
// `/-` 的作用是把紧跟着的节点整体注释掉。
// 完整配置说明可参考官方文档：
// https://yalter.github.io/niri/Configuration:-Introduction

// 输入设备相关配置。
// 完整可选项可参考：
// https://yalter.github.io/niri/Configuration:-Input
spawn-at-startup "waybar"
spawn-at-startup "fcitx5"
spawn-at-startup "bash" "/home/jdk/.config/swww-random.sh"

input {
    keyboard {
        xkb {
            // 这里可以设置 rules、model、layout、variant、options。
            // 更多说明见 xkeyboard-config(7)。

            // 例如：
            // layout "us,ru"
            // options "grp:win_space_toggle,compose:ralt,ctrl:nocaps"

            // 如果这一节保持为空，niri 会从 org.freedesktop.locale1
            // 读取当前系统键盘设置。你也可以用
            // localectl set-x11-keymap 来控制这些设置。
        }

        // 启动时开启小键盘；如果删除这行则不主动处理 NumLock。
        numlock
    }

    // 下面几节都是 libinput 设备配置。
    // 不写某项就表示保持默认值，或直接关闭覆盖。
    // 所有被注释掉的行都是示例，不代表当前启用。
    touchpad {
        // off
        tap
        // dwt
        // dwtp
        // drag false
        // drag-lock
        natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }

    mouse {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "no-scroll"
    }

    trackpoint {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "on-button-down"
        // scroll-button 273
        // scroll-button-lock
        // middle-emulation
    }

    // 取消注释后，焦点切换时鼠标会自动跳到新窗口中央。
    // warp-mouse-to-focus

    // 取消注释后，鼠标移入窗口或显示器时会自动切换焦点。
    // 如果 max-scroll-amount="0%"，则只会在窗口已经完整显示时生效。
    // focus-follows-mouse max-scroll-amount="0%"
}

// 你可以按输出名称单独配置显示器。
// 输出名称可在 niri 运行时通过 `niri msg outputs` 查看。
// 笔记本内屏通常叫做 "eDP-1"。
// 详细说明见：
// https://yalter.github.io/niri/Configuration:-Outputs
// 如需启用下面这段配置，把前面的 `/-` 改掉即可。
/-output "eDP-1" {
    // 取消注释后可关闭这个输出。
    // off

    // 输出分辨率与刷新率。
    // 格式是 "<宽>x<高>" 或 "<宽>x<高>@<刷新率>"。
    // 如果省略刷新率，niri 会为该分辨率选择最高刷新率。
    // 如果 mode 无效或完全没写，niri 会自动选择。
    // 运行中的 niri 可用 `niri msg outputs` 查看所有模式。
    mode "1920x1080@120.030"

    // 缩放比例，可用整数或小数，例如 1.5 代表 150%。
    scale 2

    // 旋转方式，可选：
    // normal、90、180、270、flipped、flipped-90、flipped-180、flipped-270。
    transform "normal"

    // 输出在全局坐标空间中的位置。
    // 这会影响例如 "focus-monitor-left" 这样的跨显示器动作和鼠标移动。
    // 鼠标只能在直接相邻的输出之间移动。
    // 输出位置需要按逻辑像素（也就是缩放后的像素）计算。
    // 例如 3840×2160 且 scale=2.0 的输出，逻辑尺寸其实是 1920×1080。
    // 所以如果想把另一块屏幕紧贴它右边，x 应该设为 1920。
    // 如果不写 position，或者写出来会发生重叠，niri 会自动摆放。
    position x=1280 y=0
}

// 影响窗口位置与尺寸的布局配置。
// 详细说明见：
// https://yalter.github.io/niri/Configuration:-Layout
layout {
    // 设置窗口之间的逻辑像素间距。
    gaps 6

    // 聚焦切换时，何时把当前列居中。
    // 可选值：
    // - "never"：默认行为，聚焦到屏幕外的列时，只把它移到左右边缘。
    // - "always"：每次切换焦点都把这一列居中。
    // - "on-overflow"：只有在当前列和上一个列放不下时才居中。
    center-focused-column "never"

    // 自定义 "switch-preset-column-width"（默认 Mod+R）切换的列宽预设。
    preset-column-widths {
        // proportion 表示占当前输出宽度的比例，会自动考虑 gaps。
        // 例如 proportion 0.25 表示刚好可并排容纳 4 列。
        // 默认预设通常是 1/3、1/2、2/3。
        proportion 0.33333
        proportion 0.5
        proportion 0.66667

        // fixed 表示固定逻辑像素宽度。
        // fixed 1920
    }

    // 你也可以给 "switch-preset-window-height"（默认 Mod+Shift+R）设置预设高度。
    // preset-window-heights { }

    // 新窗口默认列宽。
    default-column-width { proportion 0.5; }
    // 如果留空，则由应用自己决定初始宽度。
    // default-column-width {}

    // 默认情况下，焦点环和边框会作为整块背景绘制在窗口后面。
    // 这样半透明窗口也能看到焦点环，但有时会让外观不够干净。
    // 这是因为使用客户端装饰（CSD）的窗口形状可能并不规则。
    //
    // 如果你不喜欢这种效果，可以启用下面的 `prefer-no-csd`。
    // niri 会请求应用不要自己画标题栏和边框，而是让 niri 在外围绘制。
    //
    // 也可以通过 window-rule 的 `draw-border-with-background` 单独覆盖。

    // 焦点环样式。
    focus-ring {
        // 取消注释后可关闭焦点环。
        off

        // 焦点环向外延伸的逻辑像素宽度。
        width 4

        // 颜色可写成多种格式：
        // - CSS 命名颜色，例如 "red"
        // - RGB 十六进制，例如 "#rgb"、"#rgba"、"#rrggbb"、"#rrggbbaa"
        // - 类 CSS 表达，例如 rgb()、rgba()、hsl() 等

        // 活动显示器上的焦点环颜色。
        active-color "#7fc8ff"

        // 非活动显示器上的焦点环颜色。
        // 只有当焦点窗口跨显示器可见时才会看到这个颜色。
        inactive-color "#505050"

        // 也可以用渐变。渐变优先级高于纯色。
        // 写法与 CSS 的 linear-gradient(angle, from, to) 类似。
        // angle 可省略，默认是 180（从上到下）。
        // 若要配渐变，直接使用任意 CSS linear-gradient 生成器即可。
        // 也支持指定不同插值色彩空间，详见官方文档。
        //
        // active-gradient from="#80c8ff" to="#c7ff7f" angle=45

        // 也可以让渐变相对于整个工作区视图，而不是相对于单个窗口。
        // 此时可设置 relative-to="workspace-view"。
        //
        // inactive-gradient from="#505050" to="#808080" angle=45 relative-to="workspace-view"
    }

    // 常驻边框样式。和焦点环类似，但始终显示。
    border {
        // 参数和 focus-ring 基本一致。
        // 如果启用边框，通常会顺手关闭焦点环。
        off

        width 4
        active-color "#ffc87f"
        inactive-color "#505050"

        // 请求注意的窗口会使用 urgent-color。
        urgent-color "#9b0000"

        // 渐变同样支持不同色彩空间插值。
        // 例如下面这条是更柔和的彩虹渐变示例：
        //
        // active-gradient from="#e5989b" to="#ffb4a2" angle=45 relative-to="workspace-view" in="oklch longer hue"

        // inactive-gradient from="#505050" to="#808080" angle=45 relative-to="workspace-view"
    }

    // 窗口阴影。
    shadow {
        // 取消注释后启用阴影。
        // on

        // 默认阴影只画在窗口四周，不会画到窗口下方。
        // 如果想让阴影也出现在窗口后面，可启用下面这个选项。
        //
        // 需要注意的是，niri 无法知道客户端装饰窗口真正的圆角半径，
        // 只能假定窗口是直角矩形，因此圆角区域可能出现阴影伪影。
        // draw-behind-window true 可以缓解这一点。
        //
        // 但更推荐的方式通常是配合 prefer-no-csd 和 geometry-corner-radius，
        // 这样 niri 能正确理解窗口形状，并在不画到窗口后方的情况下正确绘制阴影。
        //
        // draw-behind-window true

        // 下面这些参数单位都是逻辑像素，语义与 CSS 的 box-shadow 类似。

        // softness 控制阴影模糊半径。
        softness 30

        // spread 控制阴影扩散范围。
        spread 5

        // offset 控制阴影偏移量。
        offset x=0 y=5

        // 阴影颜色与透明度。
        color "#0007"
    }

    // Struts 会像 layer-shell 面板一样，占据一部分外层空间。
    // 你可以把它理解为“额外外边距”。
    // 单位是逻辑像素。
    // 左右 strut 会保证相邻那一侧始终留有可见空间。
    // 上下 strut 会在面板空间与普通 gaps 之外再额外留白。
    struts {
        // left 64
        // right 64
        // top 64
        // bottom 64
    }
}

// 可以像这样在启动时额外拉起进程。
// 但如果你把 niri 作为完整 session 运行，也可以直接依赖 xdg-desktop-autostart。
// 下面 binds 一节里还有更多 spawn 示例。

// 如果要运行带变量、管道等 shell 语法的命令，用 spawn-sh-at-startup：
// spawn-sh-at-startup "qs -c ~/source/qs/MyAwesomeShell"

hotkey-overlay {
    // 取消注释后，启动时不再弹出“重要快捷键”提示。
    // skip-at-startup
}

// 这一项会请求支持的客户端尽量不要使用自己的客户端装饰（CSD）。
// 如果某个客户端强制要求 CSD，请求仍会被尊重。
// 同时客户端也会被告知自己处于平铺模式，这样有些窗口会去掉圆角。
// 这还能修复某些半透明窗口出现“焦点环/边框画在背景里”的问题。
// 开关这一项后，相关应用通常需要重启才能完全生效。
prefer-no-csd

// 截图保存路径。
// 开头的 `~` 会自动展开成家目录。
// 路径里的时间格式遵循 strftime(3)。
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// 如果设为 null，就不再把截图自动保存到磁盘。
// screenshot-path null

// 动画配置。
// 每个动画项的细粒度配置可参考官方文档：
// https://yalter.github.io/niri/Configuration:-Animations
animations {
    // 取消注释后可关闭所有动画。
    // off

    // slowdown 用于整体放慢动画；小于 1 则相当于加速。
    // slowdown 3.0

    // 窗口/列在工作区内移动时的动画。
    // 这里把阻尼调低、刚度调低，让移动感更明显一点。
    window-movement {
        spring damping-ratio=0.8 stiffness=500 epsilon=0.0001
    }

    // 左右切换视图、把焦点滚到相邻列时的横向移动动画。
    horizontal-view-movement {
        spring damping-ratio=0.8 stiffness=500 epsilon=0.0001
    }

    // 窗口尺寸变化时的动画。
    window-resize {
        spring damping-ratio=0.8 stiffness=500 epsilon=0.0001
    }
}

// Overview 配置。
overview {
    // 当模糊壁纸后端还没起来时，先用一个深色作为后备背景。
    backdrop-color "#11111b"
}

// 把专门用于 Overview backdrop 的壁纸层放进 backdrop。
// 这个 namespace 由 `swww-random.sh` 里单独启动的 awww/swww 实例提供。
layer-rule {
    match namespace="^(awww-daemon|swww-daemon)overview-backdrop$"
    place-within-backdrop true
}

// window-rule 可按窗口单独调整行为。
// 详细说明见：
// https://yalter.github.io/niri/Configuration:-Window-Rules

// 为 WezTerm 初次 configure 的已知问题做兼容：
// 给它一个空的 default-column-width。
window-rule {
    // 这里的正则故意写得比较严格，避免误伤其它程序。
    // 如果你愿意，也可以只写 app-id="wezterm"。
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Firefox 画中画窗口默认以浮动窗口方式打开。
window-rule {
    // 这个 app-id 正则同时兼容：
    // - 主机上原生 Firefox（app-id 是 "firefox"）
    // - Flatpak Firefox（app-id 是 "org.mozilla.firefox"）
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// 示例：把密码管理器从截图里打码。
// （这一整段因为前面有 `/-`，所以默认不生效）
/-window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^org\.gnome\.World\.Secrets$"#

    block-out-from "screen-capture"

    // 如果只想屏蔽系统截图，而允许第三方截图工具看到它们，
    // 可以改用下面这一行：
    // block-out-from "screencast"
}

// 示例：给所有窗口启用圆角。
// （同样默认不生效）
/-window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

binds {
    // 按键写法：前面是修饰键，中间用 `+` 连接，最后是 XKB 键名。
    // 如果不知道某个键的 XKB 名称，可以用 wev 之类的工具查看。
    //
    // `Mod` 是一个特殊修饰键：
    // - 在 TTY 上运行时等价于 Super
    // - 在嵌套窗口里运行时等价于 Alt
    //
    // 这里几乎所有动作也都能通过 `niri msg action ...` 方式触发。

    // Mod+Shift+/（通常等价于 Mod+?）显示重要快捷键列表。
    Mod+Shift+Slash { show-hotkey-overlay; }
    Alt+V allow-inhibiting=false { spawn "/home/jdk/.local/bin/clipway" "gui"; }
    // 启动应用的常用示例：终端、启动器、锁屏。
    Mod+Return hotkey-overlay-title="Open a Terminal: alacritty" { spawn "kitty"; }
    Mod+D hotkey-overlay-title="Run an Application: rofi" { spawn "~/.config/rofi/toggle-rofi.sh"; }

    Super+Alt+L hotkey-overlay-title="Lock the Screen: swaylock" { spawn "swaylock"; }

    // 如果命令里需要变量、管道、多条命令等 shell 语法，请使用 spawn-sh。
    // 注意：整个命令要作为一个字符串传给 `sh -c`。
    // 下面这条就是一个典型示例：切换 Orca 屏幕阅读器。
    Super+Alt+S allow-when-locked=true hotkey-overlay-title=null { spawn-sh "pkill orca || exec orca"; }

    // PipeWire / WirePlumber 音量快捷键示例。
    // allow-when-locked=true 让这些快捷键在锁屏后仍然可用。
    // 这里用 spawn-sh 是为了方便写完整 shell 命令。
    // `-l 1.0` 表示把最大音量限制在 100%。
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    // 媒体按键示例，任何支持 MPRIS 的播放器都可响应。
    XF86AudioPlay        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true { spawn-sh "playerctl next"; }

    // 亮度按键示例。
    // 这里也可以不用 spawn-sh，而是像下面这样把参数一个个拆开写。
    XF86MonBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // 打开/关闭总览模式：缩略查看所有工作区与窗口。
    // 你也可以通过把鼠标移到左上角，或者在触摸板上四指上滑来触发。
    Mod+O repeat=false { toggle-overview; }

    // 关闭当前窗口。
    Mod+Q repeat=false { close-window; }

    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }
    Mod+Right { focus-column-right; }
    Mod+H     { focus-column-left; }
    Mod+J     { focus-window-down; }
    Mod+K     { focus-window-up; }
    Mod+L     { focus-column-right; }

    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Down  { move-window-down; }
    Mod+Ctrl+Up    { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+H     { move-column-left; }
    Mod+Ctrl+J     { move-window-down; }
    Mod+Ctrl+K     { move-window-up; }
    Mod+Ctrl+L     { move-column-right; }

    // 可选：当移动到列的边缘时，继续跨工作区移动。
    // Mod+J     { focus-window-or-workspace-down; }
    // Mod+K     { focus-window-or-workspace-up; }
    // Mod+Ctrl+J { move-window-down-or-to-workspace-down; }
    // Mod+Ctrl+K { move-window-up-or-to-workspace-up; }

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }
    Mod+Shift+H     { focus-monitor-left; }
    Mod+Shift+J     { focus-monitor-down; }
    Mod+Shift+K     { focus-monitor-up; }
    Mod+Shift+L     { focus-monitor-right; }

    Mod+Shift+Ctrl+Left  { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down  { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+H     { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J     { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K     { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L     { move-column-to-monitor-right; }

    // 也有只移动单个窗口的版本：
    // Mod+Shift+Ctrl+Left { move-window-to-monitor-left; }
    // ...

    // 也可以移动整个工作区到另一块显示器：
    // Mod+Shift+Ctrl+Left { move-workspace-to-monitor-left; }
    // ...

    Mod+Page_Down      { focus-workspace-down; }
    Mod+Page_Up        { focus-workspace-up; }
    Mod+U              { focus-workspace-down; }
    Mod+I              { focus-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+U         { move-column-to-workspace-down; }
    Mod+Ctrl+I         { move-column-to-workspace-up; }

    // 也有只移动单个窗口到工作区的版本：
    // Mod+Ctrl+Page_Down { move-window-to-workspace-down; }
    // ...

    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }
    Mod+Shift+U         { move-workspace-down; }
    Mod+Shift+I         { move-workspace-up; }

    // 鼠标滚轮也可以绑定动作。
    // 这些绑定会受到 natural-scroll 设置影响。
    //
    // 如果不想滚轮切工作区切太快，可以设置 cooldown-ms 节流。
    // 实际上任何 bind 都支持 cooldown，但滚轮最常用。
    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    // 很多应用里 Shift+上下滚轮会变成横向滚动，这里模拟同样逻辑。
    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // 触摸板滚动也能绑定，不过触摸板滚动是连续的，
    // 所以 niri 会先把它切分成离散“刻度”。
    // 同样也会受到 natural-scroll 影响，因此示例方向看起来像是“反着”的。
    // Mod+TouchpadScrollDown { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02+"; }
    // Mod+TouchpadScrollUp   { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02-"; }

    // 你可以直接按索引引用工作区。
    // 但要注意：niri 的工作区是动态的，所以这里只能算“尽力而为”。
    // 如果索引大于当前工作区数量，实际上会指向最底部那个空工作区。
    //
    // 例如当前有 2 个工作区 + 1 个空工作区，那么索引 3、4、5...
    // 都会指向第 3 个工作区。
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    // 也有只移动单个窗口的版本：
    // Mod+Ctrl+1 { move-window-to-workspace 1; }

    // 在当前工作区和上一个工作区之间切换焦点。
    // Mod+Tab { focus-workspace-previous; }

    // 下面这些绑定用于把当前窗口“并入列”或“从列中弹出”。
    // 如果窗口单独一列，它会被并到旁边一列中。
    // 如果它已经在某一列里，则会被弹出成单独一列。
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    // 从右侧列吸收一个窗口到当前列底部。
    Mod+Comma  { consume-window-into-column; }
    // 把当前列最底部窗口弹出到右边。
    Mod+Period { expel-window-from-column; }

    Mod+R { switch-preset-column-width; }
    // 也可以反向循环这些预设。
    // Mod+R { switch-preset-column-width-back; }
    Mod+Shift+R { switch-preset-window-height; }
    Mod+Ctrl+R { reset-window-height; }
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    // 隐藏或显示 Waybar。
    Mod+B repeat=false { spawn-sh "killall -SIGUSR1 waybar"; }

    // 把当前列扩展到其余完全可见列之外的剩余空间。
    // 也就是常说的“占满剩余宽度”。
    Mod+Ctrl+F { expand-column-to-available-width; }

    Mod+C { center-column; }

    // 让当前屏幕上所有完整可见的列整体居中。
    Mod+Ctrl+C { center-visible-columns; }

    // 更细粒度地调列宽。
    // 这个命令支持：
    // * 直接设像素宽： "1000"
    // * 按像素微调： "-5" 或 "+5"
    // * 直接设屏宽百分比： "25%"
    // * 按百分比微调： "-10%" 或 "+10%"
    // 这里的像素单位是逻辑像素。
    // 例如在 scale=2.0 的输出上，set-column-width "100"
    // 实际会占 200 个物理像素。
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    // 在多窗口列中，细调当前窗口高度。
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // 在浮动布局和平铺布局之间切换当前窗口。
    Mod+V       { toggle-window-floating; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    // 切换当前列是否显示为“标签页列”。
    // 标签页列会把多个窗口显示成垂直标签，而不是上下堆叠。
    Mod+W { toggle-column-tabbed-display; }

    // 布局切换动作示例。
    // 注意：如果你要启用下面这些绑定，请确保没有在上面的 xkb 选项里
    // 配置相同的布局切换热键，否则按一次会被切换两次。
    // Mod+Space       { switch-layout "next"; }
    // Mod+Shift+Space { switch-layout "prev"; }

    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }

    // 有些远程桌面或软件 KVM 会请求 niri 暂停处理这些快捷键，
    // 以便把按键原样转发给远端机器。
    // 最好保留一个“逃生键”，否则某个 buggy 应用可能把你会话锁死。
    //
    // allow-inhibiting=false 也可以用在别的绑定上，
    // 表示无论 inhibitor 是否开启，这个绑定都必须由 niri 处理。
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // quit 动作会弹确认框，避免误退出。
    Mod+Shift+E { quit; }
    Ctrl+Alt+Delete { quit; }

    // 关闭显示器电源。任意输入（鼠标移动、按键）都会再次点亮。
    Mod+Shift+P { power-off-monitors; }
}
