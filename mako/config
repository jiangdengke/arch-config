# Mako 全局配置。
font=MesloLGL Nerd Font 11, LXGW WenKai Mono 11
layer=overlay
anchor=top-right
max-visible=5
sort=-time

# 通知卡片尺寸与间距。
width=360
height=140
margin=20
padding=14
border-size=2
border-radius=12
max-icon-size=48

# 主题配色。
background-color=#1f1d2edd
text-color=#e0def4ff
border-color=#9ccfd8ff
progress-color=over #31748fdd

# 文本与交互。
markup=1
actions=1
icons=1
default-timeout=5000
ignore-timeout=1
group-by=summary
format=<b>%s</b>\n%b

# 低优先级通知更快消失。
[urgency=low]
default-timeout=3000

# 高优先级通知使用更醒目的边框颜色。
[urgency=high]
border-color=#eb6f92ff
default-timeout=0

# 勿扰模式：进入后直接隐藏通知。
[mode=do-not-disturb]
invisible=1
